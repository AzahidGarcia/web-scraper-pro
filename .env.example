# web-scraper-pro — environment variables
# Copy this file to .env and fill in values.

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Requests per second per host (float, default 1.0)
SCRAPER_RATE_LIMIT=1.0

# ─── HTTP ─────────────────────────────────────────────────────────────────────
# Request timeout in seconds
SCRAPER_TIMEOUT=30

# Custom User-Agent (leave blank for default)
SCRAPER_USER_AGENT=

# ─── Retries ──────────────────────────────────────────────────────────────────
SCRAPER_MAX_RETRIES=3

# ─── Playwright ───────────────────────────────────────────────────────────────
# Set to "1" to enable JS-heavy scraping via Playwright
SCRAPER_USE_PLAYWRIGHT=0

# ─── Watch / scheduling ───────────────────────────────────────────────────────
# Default watch interval (e.g. "1h", "30m", "60s")
SCRAPER_WATCH_INTERVAL=1h
